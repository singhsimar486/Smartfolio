# Database (Render provides this automatically when you add PostgreSQL)
DATABASE_URL=postgresql://username:password@host:5432/railway

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (set to your Vercel frontend URL in production)
FRONTEND_URL=http://localhost:4200

# Market Data API (free tier)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Optional: AI Service Keys
OPENAI_API_KEY=your-openai-key-if-using
